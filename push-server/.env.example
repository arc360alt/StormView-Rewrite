# Run `npm run generate-keys` to generate these two values
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Your email — included in VAPID auth so NWS can contact you if needed
CONTACT_EMAIL=you@example.com

# The URL your frontend is served from (used for CORS)
# e.g. https://stormview.arc360hub.com
FRONTEND_ORIGIN=https://stormview.arc360hub.com

# Port for the API server (default 3001)
PORT=3001
